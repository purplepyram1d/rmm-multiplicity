<group name="sysmon,rmm,">

  <!-- 100210: identify an RMM process by embedded PE Company metadata (rename-proof). -->
  <rule id="100210" level="3">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.company">AnyDesk Software GmbH|TeamViewer|Atera Networks|Splashtop|MeshCentral|ConnectWise</field>
    <description>RMM process launched: $(win.eventdata.company)</description>
    <mitre><id>T1219</id></mitre>
    <group>rmm_detected,</group>
  </rule>

</group>